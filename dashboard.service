[Unit]
Description=Antifragile dashboard (Telegram Mini App)
After=network.target

[Service]
WorkingDirectory=/opt/antifragile
EnvironmentFile=/opt/antifragile/secrets.env
ExecStart=/opt/antifragile/venv/bin/gunicorn -w 2 -b 127.0.0.1:8080 server:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
